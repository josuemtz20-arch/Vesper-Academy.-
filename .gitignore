# ============================================================
# Vesper Academy — PUBLIC repo whitelist
# Default: EVERYTHING at the root is ignored (private/local).
# Only the explicitly un-ignored files below are published.
# Teacher manuals, answer keys, generators (*.py), data banks,
# admin tools, _scripts/ and _archive/ stay local-only.
# ============================================================
/*

# repo plumbing
!/.gitignore
!/.nojekyll
!/CNAME
# mapa del repo + modelo de seguridad (sin claves)
!/README.md

# planning note for the AI-guardian work (picked up by a new web session)
!/GUARDIANS_TODO.md

# public site + auth gate (must stay at root)
# (vesper_web/landing/promo stay local: index.html is the one canonical landing)
!/index.html
!/login.html
!/access_admin.html
!/vesper_auth.js

# student portal + tools
# (exam.html is PUBLISHED but login-gated; its DATA + answer keys stay LOCAL and
#  are served from Firestore — see the per-course exam block further down.)
!/materiales.html
!/onboarding.html
!/perfil.html
!/book_placement.html
!/audio_library.html
!/lesson.html
# Pizarra Virtual autónoma (2026-07-08): app estática de whiteboard con Fabric.js
# por CDN (sin build). Vive en /whiteboard/ (URL limpia vesperacademy.com/whiteboard).
# Sin claves. El código fuente React/Vite (vesper-whiteboard/) queda local-only.
!/whiteboard/
!/whiteboard/index.html
# Barra de navegación persistente del alumno (Inicio/Aprender/Audio/Boleta/Perfil).
# Se auto-inyecta en materiales/leccion/audio_library/mi_boleta/chat/perfil. Sin claves.
!/vesper_nav.js
# Enlace automático cuenta Firebase <-> identidad local (nombre/alias/liga).
# No destructivo; sin sesión no hace nada. Requiere vesper_auth.js. Sin claves.
!/vesper_identity.js
# SEO: landings de descubrimiento (2026-06-23) + indexación. Estáticas,
# indexables, embudan al examen con atribución ?src=. Sin claves.
!/examen-ingles-gratis.html
!/ingles-para-call-center.html
# Páginas de detalle de curso/plan (marketing, públicas, sin gate ni claves).
# Enlazadas desde la fila de íconos de index.html #cursos / #precios. Comparten
# assets/css/vesper_course.css (ya whitelisted vía !/assets/).
!/curso-ingles-general.html
!/curso-club-conversacion.html
!/curso-ingles-corporativo.html
!/curso-certificacion.html
!/planes.html
!/robots.txt
!/sitemap.xml
# 404 con marca para GitHub Pages (estática, sin claves, noindex).
!/404.html

# teacher portal (index ONLY — password-gated).
# The teacher manuals stay local-only and are never published: the portal
# opens them via manual.html, which downloads them from Firestore where
# server-side rules only allow approved teacher accounts to read.
!/portal_profesores.html
!/manual.html

# student book viewer: downloads the books from Firestore, where
# server-side rules only allow approved student/teacher accounts to read.
!/libro.html

# Per-course end-of-level exams (login-gated: exam.html is NOT in publicPages).
# One exam per teacher manual/level, self-graded MCQs + teacher-graded Writing &
# Speaking, score logged to exam_results (portal_calificaciones.html).
# The exam VIEWER is published; the exam DATA (with answer keys) is NOT — it lives
# in Firestore (collection "exams"), fetched with the student's idToken, exactly
# like manuals/books. Regenerate the bank with _scripts/build_exams.py and upload
# with `python _scripts/upload_manuals.py upload-exams`.  vesper_exam_data.js stays
# LOCAL (it carries answer keys). The id-only index below has NO answers and just
# lets manual.html/libro.html show the "exam" chip.
!/exam.html
!/vesper_exam_index.js

# Vesper Engine v2.0 — personalized course prompt builder (teacher-gated).
# The syllabus data comes from the already-public student books.
!/vesper_engine.html
!/vesper_engine_data.js

# Vesper Engine PWA (installable app): manifest + service worker.
# App icons live under assets/images/ (already whitelisted below).
!/manifest.webmanifest
!/manifest_lecciones.webmanifest
!/sw.js

# Play Store (TWA) packaging for the free-lessons PWA.
# assetlinks.json MUST be published (Digital Asset Links verification).
# twa-manifest.json + the guide are repo config; published is harmless.
# The keystore and the generated .aab/.apk binaries stay LOCAL (see below).
!/.well-known/
!/twa-manifest.json
!/PLAY_STORE.md
*.keystore
*.aab
*.apk

# lesson data consumed by the public pages
!/vesper_audio_data.js
!/vesper_reading_data.js
!/vesper_basics_audio_data.js
!/vesper_biz_path_audio_data.js
!/vesper_basics_lesson_data.js
!/vesper_custom_transcripts.js
!/vesper_covers.js
!/vesper_lesson_images.js
# topic search index for the student hub: lesson TITLES only (no bodies/answers),
# autogenerated by _scripts/generate_book_index.py from the local book sources.
!/vesper_book_index.js

# student books are NOT published anymore: they live in Firestore
# (collection "studentbooks") and are served via libro.html to
# approved accounts only. Source files stay local-only on disk;
# re-upload after editing: python _scripts/upload_manuals.py upload-books

# Free lessons layer (no-account, public). Vanilla static, added 2026-06-12.
# Account-free interactive lessons: player + content + mascot config + progress store.
# leccion.html does NOT load vesper_auth.js, so it never hits the login gate.
!/leccion.html
!/vesper_lessons.js
!/vesper_mascot.js
!/vesper_progress.js
!/vesper_sync.js

# Expansion 2026-06-14: appearance "models" (themes + mascot skins),
# adaptive lessons (onboarding profile + start-of-session warm-up) and
# the expanded activity bank (true/false, fill-blank, matching,
# listening, translate, categorize). All vanilla static, no-account.
!/vesper_theme.js
!/vesper_adaptive.js
!/vesper_activities.js
!/vesper_path.js
# Instrumentación del embudo gratis->lead (2026-06-23): eventos locales +
# passthrough opcional a GA4 + atribución ?src=. Sin claves (reutiliza la
# apiKey pública de vesper_auth.js). La usan leccion.html y book_placement.html.
!/vesper_analytics.js
# Cosméticos de Vesper (2026-06-22): colores/accesorios que se desbloquean con el
# progreso. Catálogo de requisitos + evaluación; lee VesperProgress. Sin claves.
!/vesper_cosmetics.js
# Engagement 2026-06-23 (comparativa Duolingo): repaso espaciado de errores
# (Leitner) y economía opcional (vidas + gemas + tienda). Vanilla, sin claves.
!/vesper_srs.js
!/vesper_economy.js
!/tienda.html
# Liga semanal competitiva (rivales simulados, lado cliente). Sin claves.
!/vesper_league.js
!/liga.html
# Leaderboard real (Firestore REST, reusa VesperAuth) + efectos de sonido
# compartidos (WebAudio + haptics). Sin claves. Doc de la regla a publicar.
!/vesper_league_cloud.js
!/vesper_sfx.js
!/vesper_icons.js
!/vesper_opticons.js
!/FIRESTORE_LEAGUE_RULES.md
# Ruleset completo de Firestore (base teachermanuals): allowlist, manuales,
# libros, progreso, liga y exam_results. Referencia desplegable.
!/firestore.rules
# Registro central de calificaciones (2026-06-26): los exámenes (boss/lección/
# nivelación) guardan su resultado en exam_results (Firestore REST, reusa
# VesperAuth) espejado a localStorage; el profesor los consulta en
# portal_calificaciones.html (gated). Sin claves. Doc de la regla a publicar.
!/vesper_results.js
!/portal_calificaciones.html
!/FIRESTORE_EXAM_RESULTS_RULES.md
# Boleta de calificaciones (2026-07-03): una fila por alumno, tabla genérica
# para todos los niveles (A1–C2). Exámenes/lecciones automáticos (exam_results)
# + participación manual del profe (colección gradebook; regla en su doc).
!/portal_boleta.html
!/vesper_gradebook.js
!/FIRESTORE_GRADEBOOK_RULES.md
# Leads del examen diagnóstico (2026-07-14): book_placement.html guarda cada
# nivelación anónima en placement_results (create sin sesión, validado; read
# solo profes/admin). Doc de la regla a publicar.
!/FIRESTORE_PLACEMENT_RULES.md
# Panel de leads del examen diagnostico (solo profes/admin): lee
# placement_results con el token del profesor. Ver FIRESTORE_PLACEMENT_RULES.md.
!/portal_leads.html
# ... y la vista del alumno: cada quien consulta SOLO su boleta (misma regla).
!/mi_boleta.html
# recintos tematicos de vocabulario (ramas) — datos publicos, sin claves
!/vesper_vocab_dens.js
!/apariencia.html

# Expansion 2026-06-15 (Front 2): Vesper personalization. The "Configuracion"
# panel + the persona engine that turns prefs into a dynamic system prompt,
# a live preview and behavior hooks (tone lines, language mix, corrections).
!/vesper_persona.js
!/configuracion.html

# Expansion 2026-06-16: big content pack (reading/listening/grammar/vocab/use
# lessons) + new "reading" skill. Vanilla static, no-account; merged into
# VESPER_LESSONS at boot by leccion.html.
!/vesper_content_pack.js

# Expansion 2026-06-17: 28 new lessons (A1–C2 + a "Inglés profesional"
# Business track) merged at boot, plus a shared design-tokens stylesheet
# and an in-hub lesson search/filter. Vanilla static, no-account.
!/vesper_expansion.js

# Expansion 2026-06-17 (b): 32 more lessons (reinforces C1/C2 + professional
# track), plus vesper_prefs.js — applies accessibility/sound preferences from
# Configuración (text size, contrast, reduced motion, sound) across the site.
!/vesper_expansion2.js
!/vesper_prefs.js

# Expansion 3: 39 more lessons + vocabulary across all levels (A1-C2),
# all skills (grammar, vocab, reading, listening, practical use). Vocabulary
# lessons feed the vocab dens automatically via their matching pairs.
!/vesper_expansion3.js

# Expansion 2026-06-19: TOEFL-style lessons for the advanced worlds (B2/C1/C2)
# — academic reading passages, listening lectures and structure/writing tasks.
# Merged into VESPER_LESSONS at boot by leccion.html; level progression is
# handled by vesper_path.js. Vanilla static, no-account.
!/vesper_toefl_pack.js

# Expansion 2026-06-19 (b): base-level reinforcement (A1/A2/B1) — grammar,
# vocabulary and reading lessons with level-appropriate difficulty, including
# the new "find the error" (find_error) exercise type. Merged at boot.
!/vesper_levels_pack.js

# Expansion 2026-06-19 (c): themed lessons for A1/A2/B1 — each theme brings
# a vocabulary lesson and a listening lesson (TTS, no audio files), with
# level-appropriate difficulty. Merged at boot.
!/vesper_themes_pack.js

# Expansion 2026-06-19 (d): extra themes for A1/A2/B1 (house, health, tech:
# vocab + listening) plus thematic listening for the advanced worlds
# (B2/C1/C2: meetings, news, psychology, society, ethics, development).
!/vesper_themes_pack2.js

# Expansion 2026-06-19 (e): more themes for A1/A2/B1 (city, jobs, sport:
# vocab + listening) and thematic reading + vocabulary for B2/C1/C2
# (gig economy, AI, philosophy of happiness, collocations, trends, nuance).
!/vesper_themes_pack3.js

# Expansion 2026-06-20: dedicated boss exam banks (fresh wording/contexts,
# sampled each attempt). C1/C2 are short TOEFL-style exams (reading +
# listening + structure). Consumed by buildBossExam in leccion.html.
!/vesper_boss_exams.js

# Examen de nivel formal por CEFR (2026-06-26): banco completo por nivel
# (gramática, vocab, uso, lectura, listening) + enriquecimiento de los boss
# banks. Lo consume buildLevelExam (exam:NIVEL) en leccion.html y se registra
# en el panel de calificaciones. Vanilla, sin claves.
!/vesper_level_exams.js

# Expansion 2026-06-16: live chat with the Vesper AI tutor (public, no-account).
# chat.html embeds the personalized system prompt from VESPER_PERSONA and talks
# to Claude through a Cloudflare Worker proxy that hides the API key. The proxy
# source + deploy docs live in worker/ (NO secrets in these files — the API key
# is stored as a wrangler secret, never committed).
!/chat.html
!/worker/

# css / images / audio used by all public pages
!/assets/

# Rive runtime (rive.js/.wasm): solo-local hasta que exista el .riv del usuario
# (no enviar ~1.7 MB sin usar). Ver RIVE_SETUP.md.
assets/rive/

# mascot full-res source: keep local, don't ship the 2.9 MB original
assets/images/mascot/vesper_cat_full.png

# never publish these even if they appear inside whitelisted dirs
__pycache__/
*.pyc
*.lnk
