rules_version = '2';

/* ============================================================
 * Vesper Academy — Reglas de Firestore, base "(default)"
 * ------------------------------------------------------------
 * Publica ESTE archivo en: consola de Firebase → Firestore →
 * seleccionar la base "(default)" → pestaña Reglas → pegar → Publicar.
 * (La base "teachermanuals" tiene su propio archivo: firestore.rules.)
 *
 * En (default) solo vive placement_results: los LEADS del examen de
 * nivelación público (book_placement.html), que se crean SIN sesión
 * (solo con la apiKey pública del sitio).
 *
 * 🔒 PRIVACIDAD — lectura pública CERRADA:
 *     Estos docs llevan nombre, correo y teléfono de cada lead. Si la
 *     lectura fuera pública, cualquiera podría descargar tu lista de
 *     prospectos completa con un curl. Por eso: crear sí (es un
 *     formulario público), leer NO. Consecuencia aceptada: el botón
 *     "Ver historial" de book_placement.html solo mostrará el historial
 *     guardado en el dispositivo (el código ya degrada solo); la copia
 *     completa te sigue llegando por correo (FormSubmit) y puedes verla
 *     en la consola de Firebase cuando quieras.
 * ============================================================ */
service cloud.firestore {
  match /databases/{database}/documents {

    match /placement_results/{id} {
      // alta anónima del lead, con forma y tamaños acotados (anti-abuso)
      allow create: if request.resource.data.keys().hasOnly(
                         ["name", "email", "phone", "level", "levelName",
                          "correct", "total", "skipped", "scores",
                          "origin", "createdAt"])
                    && request.resource.data.name is string
                    && request.resource.data.name.size() <= 80
                    && request.resource.data.email is string
                    && request.resource.data.email.size() <= 120
                    && request.resource.data.phone is string
                    && request.resource.data.phone.size() <= 30
                    && request.resource.data.level is string
                    && request.resource.data.level.size() <= 10
                    && request.resource.data.levelName is string
                    && request.resource.data.levelName.size() <= 40
                    && request.resource.data.correct is int
                    && request.resource.data.total is int
                    && request.resource.data.skipped is int
                    && request.resource.data.correct >= 0
                    && request.resource.data.correct <= request.resource.data.total
                    && request.resource.data.total <= 200
                    && request.resource.data.scores is map
                    && request.resource.data.origin is string
                    && request.resource.data.origin.size() <= 60
                    && request.resource.data.createdAt is timestamp;
      // los datos de contacto de tus leads NO son públicos
      allow read, update, delete: if false;
    }

    // cualquier otra colección de (default): cerrada
    match /{document=**} {
      allow read, write: if false;
    }
  }
}
