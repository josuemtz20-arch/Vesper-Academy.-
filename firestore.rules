rules_version = '2';

/* ============================================================
 * Vesper Academy — Reglas de Firestore (base "teachermanuals")
 * ============================================================ */
service cloud.firestore {
  match /databases/{database}/documents {

    // El admin sube manuales/libros/allowlists con SU idToken (no service account).
    function isAdmin() {
      return request.auth != null
             && request.auth.token.email == "josuemtz20@gmail.com";
    }

    function isTeacherUser() {
      return request.auth != null
             && exists(/databases/$(database)/documents/teachers/$(request.auth.token.email));
    }
    function teacherSeesGroup(g) {
      return isTeacherUser()
             && g != ""
             && g in get(/databases/$(database)/documents/teachers/$(request.auth.token.email)).data.groups;
    }
    function ownSid() {
      return get(/databases/$(database)/documents/students/$(request.auth.token.email)).data.sid;
    }

    // —— Acceso por curso: si students/{correo} tiene campo `books` (lista de
    //    ids permitidos), el alumno SOLO abre esos libros y examenes. Sin
    //    `books` = acceso a todo (compatibilidad hacia atras). ——
    function isStudentUser() {
      return request.auth != null
             && exists(/databases/$(database)/documents/students/$(request.auth.token.email));
    }
    function studentBookAllowed(id) {
      return isStudentUser()
             && (
               !("books" in get(/databases/$(database)/documents/students/$(request.auth.token.email)).data)
               || id in get(/databases/$(database)/documents/students/$(request.auth.token.email)).data.books
             );
    }

    // —— Allowlist: cada quien lee SOLO su propio doc (id = correo) ——
    match /students/{email} {
      allow read:  if request.auth != null && request.auth.token.email == email;
      allow write: if isAdmin();
    }
    match /teachers/{email} {
      allow read:  if request.auth != null && request.auth.token.email == email;
      allow write: if isAdmin();
    }

    // —— Manuales del profesor: solo profesores autorizados o el admin ——
    match /manuals/{id} {
      allow read:  if request.auth != null && (
                     exists(/databases/$(database)/documents/teachers/$(request.auth.token.email))
                     || request.auth.token.email == "josuemtz20@gmail.com"
                   );
      allow write: if isAdmin();
      match /chunks/{n} {
        allow read:  if request.auth != null && (
                       exists(/databases/$(database)/documents/teachers/$(request.auth.token.email))
                       || request.auth.token.email == "josuemtz20@gmail.com"
                     );
        allow write: if isAdmin();
      }
    }

    // —— Libros del alumno: acceso por curso (studentBookAllowed), profesor o admin ——
    match /studentbooks/{id} {
      allow read:  if request.auth != null && (
                     studentBookAllowed(id)
                     || exists(/databases/$(database)/documents/teachers/$(request.auth.token.email))
                     || request.auth.token.email == "josuemtz20@gmail.com"
                   );
      allow write: if isAdmin();
      match /chunks/{n} {
        allow read:  if request.auth != null && (
                       studentBookAllowed(id)
                       || exists(/databases/$(database)/documents/teachers/$(request.auth.token.email))
                       || request.auth.token.email == "josuemtz20@gmail.com"
                     );
        allow write: if isAdmin();
      }
    }

    // —— Examenes por curso/manual: acceso por curso, profesor o admin ——
    match /exams/{id} {
      allow read:  if request.auth != null && (
                     studentBookAllowed(id)
                     || exists(/databases/$(database)/documents/teachers/$(request.auth.token.email))
                     || request.auth.token.email == "josuemtz20@gmail.com"
                   );
      allow write: if request.auth != null
                   && request.auth.token.email == "josuemtz20@gmail.com";
    }

    // —— Progreso del alumno (racha + XP): self-scoped ——
    match /progress/{uid} {
      allow read, write: if request.auth != null && request.auth.uid == uid;
    }

    // —— Liga semanal: lee cualquier autenticado; escribe SOLO su entrada ——
    match /leagues/{week}/members/{uid} {
      allow read:  if request.auth != null;
      allow write: if request.auth != null
                   && request.auth.uid == uid
                   && request.resource.data.xp is int;
    }

    // —— Roster (espejo sin correo) ——
    match /roster/{sid} {
      allow read:  if isAdmin() || teacherSeesGroup(resource.data.group);
      allow write: if isAdmin();
    }

    // —— Resultados de examenes: el alumno crea lo suyo; inmutables ——
    match /exam_results/{id} {
      allow create: if request.auth != null
                    && request.resource.data.studentUid == request.auth.uid
                    && request.resource.data.percent is int;
      allow read:   if request.auth != null && (
                       resource.data.studentUid == request.auth.uid
                       || request.auth.token.email == "josuemtz20@gmail.com"
                       || teacherSeesGroup(resource.data.group)
                    );
      allow update, delete: if false;
    }

    // —— Boleta de calificaciones ——
    match /gradebook/{sid} {
      allow read:  if request.auth != null && (
                     ownSid() == sid
                     || request.auth.token.email == "josuemtz20@gmail.com"
                     || teacherSeesGroup(get(/databases/$(database)/documents/roster/$(sid)).data.group)
                   );
      allow write: if request.auth != null
                   && (request.auth.token.email == "josuemtz20@gmail.com"
                       || teacherSeesGroup(get(/databases/$(database)/documents/roster/$(sid)).data.group))
                   && (!("participacion" in request.resource.data)
                       || (request.resource.data.participacion is int
                           && request.resource.data.participacion >= 0
                           && request.resource.data.participacion <= 100))
                   && (!("examsGrade" in request.resource.data)
                       || (request.resource.data.examsGrade is int
                           && request.resource.data.examsGrade >= 0
                           && request.resource.data.examsGrade <= 100))
                   && (!("lessonsGrade" in request.resource.data)
                       || (request.resource.data.lessonsGrade is int
                           && request.resource.data.lessonsGrade >= 0
                           && request.resource.data.lessonsGrade <= 100));
    }

    // —— Progreso diario ——
    match /daily_progress/{sid} {
      allow read:  if request.auth != null && (
                     ownSid() == sid
                     || request.auth.token.email == "josuemtz20@gmail.com"
                     || teacherSeesGroup(get(/databases/$(database)/documents/roster/$(sid)).data.group)
                   );
      allow write: if request.auth != null
                   && (request.auth.token.email == "josuemtz20@gmail.com"
                       || teacherSeesGroup(get(/databases/$(database)/documents/roster/$(sid)).data.group));
    }

    // —— Telemetria opcional ——
    match /app_events/{id} {
      allow create: if request.resource.data.keys().hasOnly(['event','props','vid','sid','page','createdAt'])
                    && request.resource.data.event is string && request.resource.data.event.size() <= 80
                    && request.resource.data.props is string && request.resource.data.props.size() <= 2000
                    && request.resource.data.vid   is string && request.resource.data.vid.size()   <= 64
                    && request.resource.data.sid   is string && request.resource.data.sid.size()   <= 64
                    && request.resource.data.page  is string && request.resource.data.page.size()  <= 200
                    && request.resource.data.createdAt is timestamp;
      allow read, update, delete: if isAdmin();
    }

    // —— Leads del examen diagnostico (nivelacion publica, SIN registro) ——
    // (book_placement.html -> /documents/placement_results/{autoId})
    // El examen es publico y anonimo: el ALTA la hace un visitante SIN token
    // (request.auth == null), por eso `create` NO exige auth; valida la forma
    // del doc y exige al menos un dato de contacto. La LECTURA es solo para
    // profes/admin (los leads traen correo/telefono). Intentos inmutables.
    match /placement_results/{id} {
      allow create: if request.resource.data.name is string
                    && request.resource.data.name.size() > 0
                    && request.resource.data.name.size() <= 120
                    && request.resource.data.level is string
                    && request.resource.data.level.size() <= 20
                    && request.resource.data.correct is int
                    && request.resource.data.total is int
                    && request.resource.data.correct >= 0
                    && request.resource.data.total >= 0
                    && request.resource.data.correct <= request.resource.data.total
                    && request.resource.data.email is string
                    && request.resource.data.email.size() <= 200
                    && request.resource.data.phone is string
                    && request.resource.data.phone.size() <= 60
                    && (request.resource.data.email.size() > 0
                        || request.resource.data.phone.size() > 0);
      allow read:   if isAdmin() || isTeacherUser();
      allow update, delete: if false;
    }

  }
}
