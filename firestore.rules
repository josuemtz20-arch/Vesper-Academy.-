rules_version = '2';

/* ============================================================
 * Vesper Academy — Reglas de Firestore, base "teachermanuals"
 * ------------------------------------------------------------
 * ESTE archivo es el que se publica: consola de Firebase → Firestore →
 * seleccionar la base "teachermanuals" → pestaña Reglas → pegar TODO →
 * Publicar. (La base "(default)" tiene su propio archivo:
 * firestore.default.rules — ver ahí placement_results.)
 *
 * Cubre TODO lo que el sitio lee/escribe hoy:
 *   students/ teachers/ (allowlist) · manuals/ studentbooks/ exams/
 *   progress/ · leagues/ · exam_results/ · roster/ · gradebook/
 *   daily_progress/ (boleta por sid) · app_events (analytics).
 *
 * 🔒 SEGURIDAD — correo VERIFICADO obligatorio:
 *     Firebase Auth permite crear una cuenta con CUALQUIER correo (ajeno)
 *     sin verificarlo, usando la API pública con la apiKey del sitio. Por
 *     eso TODA regla que confíe en request.auth.token.email exige además
 *     email_verified == true (helper verifiedEmail()). El cliente ya exige
 *     correo verificado en todos sus flujos, así que no rompe nada.
 *     La cuenta del admin debe tener su correo verificado (una vez).
 *
 * Modelo de grupos y privacidad (2026-07-07):
 *   - students/{correo}.sid  = hash opaco del correo (sid_of() del script
 *     admin); .group = grupo del alumno.
 *   - teachers/{correo}.groups = lista de grupos que ese profesor ve.
 *   - roster/{sid} = espejo SIN correo de la allowlist (name/level/
 *     levelName/group). El profesor ve NOMBRES, nunca correos.
 *   - gradebook/{sid} y daily_progress/{sid}: la boleta. El alumno lee
 *     SOLO la suya (students/{su correo}.sid == sid); el profesor solo
 *     las de SUS grupos (roster/{sid}.group ∈ sus groups); admin todo.
 *   - exam_results: el alumno crea lo suyo; el profesor solo LEE intentos
 *     de sus grupos (query `group == g`); admin todo. Inmutables.
 *
 * Acceso POR CURSO (2026-07-07, reintegrado 2026-07-08):
 *   - students/{correo}.books = lista opcional de ids de curso permitidos.
 *     Si existe, el alumno SOLO abre esos libros (studentbooks/) y sus
 *     exámenes (exams/); si NO existe, ve TODO (compat hacia atrás). Admin y
 *     profesores siempre ven todo. Helper: studentBookAllowed(id).
 *
 * El alta/baja (manuales, libros, allowlist, roster) la hace
 * _scripts/upload_manuals.py INICIANDO SESIÓN COMO EL ADMIN (idToken),
 * por eso esas escrituras permiten isAdmin() y no `if false`.
 * ============================================================ */
service cloud.firestore {
  match /databases/{database}/documents {

    /* ---------- helpers ---------- */

    // Correo del token VERIFICADO: la única forma segura de confiar en
    // request.auth.token.email (ver nota de seguridad en la cabecera).
    function verifiedEmail() {
      return request.auth != null
             && request.auth.token.email_verified == true;
    }

    function isAdmin() {
      return verifiedEmail()
             && request.auth.token.email == "josuemtz20@gmail.com";
    }

    // ¿Usuario (verificado) en la allowlist de profesores?
    function isTeacher() {
      return verifiedEmail()
             && exists(/databases/$(database)/documents/teachers/$(request.auth.token.email));
    }

    // Grupos asignados al profesor con sesión ([] si no tiene campo groups).
    function myGroups() {
      return get(/databases/$(database)/documents/teachers/$(request.auth.token.email))
               .data.get('groups', []);
    }

    // ¿Este profesor tiene asignado el grupo g?
    function teacherSeesGroup(g) {
      return isTeacher() && g in myGroups();
    }

    // sid del alumno con sesión (sembrado por el admin en students/{correo}).
    // El exists() previo evita que get() sobre un doc ausente (p. ej. un
    // profesor, que no tiene doc en students/) haga fallar toda la regla.
    function ownSid(sid) {
      return verifiedEmail()
             && exists(/databases/$(database)/documents/students/$(request.auth.token.email))
             && get(/databases/$(database)/documents/students/$(request.auth.token.email))
                  .data.get('sid', '') == sid;
    }

    // ¿Este profesor tiene asignado el grupo del alumno {sid} (según el
    // roster que mantiene el script admin)? Con guarda exists() para que un
    // sid sin entrada en roster deniegue en vez de errar.
    function teacherOfSid(sid) {
      return isTeacher()
             && exists(/databases/$(database)/documents/roster/$(sid))
             && get(/databases/$(database)/documents/roster/$(sid))
                  .data.get('group', '') in myGroups();
    }

    // ¿Usuario (verificado) en la allowlist de alumnos?
    function isStudent() {
      return verifiedEmail()
             && exists(/databases/$(database)/documents/students/$(request.auth.token.email));
    }

    // Acceso POR CURSO (opcional, 2026-07-07): si students/{correo} tiene el
    // campo `books` (lista de ids de curso/libro), el alumno SOLO puede abrir
    // esos ids (libro Y su examen comparten id). Si NO tiene `books`, ve TODO
    // (compat: los alumnos dados de alta antes de esta función no se afectan).
    // Lo escribe el script admin con add-student --books / set-courses. Admin y
    // profesores no pasan por aquí: ellos ven todo (ver los match de abajo).
    function studentBookAllowed(id) {
      return isStudent()
             && (
               !("books" in get(/databases/$(database)/documents/students/$(request.auth.token.email)).data)
               || id in get(/databases/$(database)/documents/students/$(request.auth.token.email)).data.books
             );
    }

    /* ---------- allowlist de acceso ---------- */
    // Cada quien lee SOLO su propio doc (id = correo en minúsculas);
    // vesper_auth.js lo consulta para decidir el acceso al campus.
    match /students/{email} {
      allow read:  if verifiedEmail() && request.auth.token.email == email;
      allow write: if isAdmin();
    }
    match /teachers/{email} {
      allow read:  if verifiedEmail() && request.auth.token.email == email;
      allow write: if isAdmin();
    }

    /* ---------- manuales del profesor (manual.html) ---------- */
    match /manuals/{id} {
      allow read:  if isTeacher() || isAdmin();
      allow write: if isAdmin();
      match /chunks/{n} {
        allow read:  if isTeacher() || isAdmin();
        allow write: if isAdmin();
      }
    }

    /* ---------- libros del alumno (libro.html) ----------
       Admin y profesores ven todo; el alumno, solo los libros que su
       allowlist permite (studentBookAllowed: todos si no tiene lista `books`). */
    match /studentbooks/{id} {
      allow read:  if isAdmin() || isTeacher() || studentBookAllowed(id);
      allow write: if isAdmin();
      match /chunks/{n} {
        allow read:  if isAdmin() || isTeacher() || studentBookAllowed(id);
        allow write: if isAdmin();
      }
    }

    /* ---------- exámenes con clave de respuesta (exam.html) ----------
       Mismo gate por curso que el libro: el examen comparte id con su curso,
       así un alumno con lista `books` solo abre los exámenes de sus cursos. */
    match /exams/{id} {
      allow read:  if isAdmin() || isTeacher() || studentBookAllowed(id);
      allow write: if isAdmin();
    }

    /* ---------- progreso del alumno: racha + XP (vesper_sync.js) ---------- */
    match /progress/{uid} {
      allow read, write: if verifiedEmail() && request.auth.uid == uid;
    }

    /* ---------- liga semanal (vesper_league_cloud.js) ---------- */
    match /leagues/{week}/members/{uid} {
      allow read:  if verifiedEmail();
      allow write: if verifiedEmail()
                   && request.auth.uid == uid
                   && request.resource.data.xp is int;
    }

    /* ---------- resultados de exámenes (vesper_results.js) ----------
       El alumno CREA sus intentos (autocalificación => son PRÁCTICA, no la
       nota oficial; la nota la confirma el profesor en gradebook). Lee: el
       dueño, el admin, o un profesor DEL GRUPO del intento (su panel lanza
       queries `where group == g` por cada grupo suyo). Inmutables. */
    match /exam_results/{id} {
      allow create: if verifiedEmail()
                    && request.resource.data.studentUid == request.auth.uid
                    && request.resource.data.score is int
                    && request.resource.data.total is int
                    && request.resource.data.percent is int
                    && request.resource.data.score >= 0
                    && request.resource.data.total >= 0
                    && request.resource.data.score <= request.resource.data.total
                    && request.resource.data.percent >= 0
                    && request.resource.data.percent <= 100
                    // percent debe cuadrar con score/total (±1 por redondeo)
                    && (
                         (request.resource.data.total == 0 && request.resource.data.percent == 0)
                         || (request.resource.data.total > 0
                             && request.resource.data.percent * request.resource.data.total
                                >= (request.resource.data.score * 100) - request.resource.data.total
                             && request.resource.data.percent * request.resource.data.total
                                <= (request.resource.data.score * 100) + request.resource.data.total)
                       )
                    && request.resource.data.examType in ["lesson", "exam", "boss", "placement"];
      allow read:   if request.auth != null && (
                       resource.data.studentUid == request.auth.uid
                       || isAdmin()
                       || ("group" in resource.data
                           && teacherSeesGroup(resource.data.group))
                    );
      allow update, delete: if false;
    }

    /* ---------- roster: espejo sin correo de la allowlist ----------
       Lo escribe SOLO el script admin (add-student / set-group /
       sync-roster). El admin lista todo; un profesor solo puede consultar
       `where group == <uno de sus grupos>`. */
    match /roster/{sid} {
      allow read:  if isAdmin()
                   || ("group" in resource.data
                       && teacherSeesGroup(resource.data.group));
      allow write: if isAdmin();
    }

    /* ---------- boleta: parte manual del profesor (gradebook/{sid}) ----------
       Lee: el propio alumno (students/{correo}.sid == sid), los profesores
       del grupo del alumno (roster/{sid}.group ∈ sus groups) y el admin.
       Escribe: SOLO profes del grupo o admin. participacion / examsGrade /
       lessonsGrade son OPCIONALES por escritura, pero si vienen deben ser
       int 0..100 (validación por campo). */
    match /gradebook/{sid} {
      allow read:  if isAdmin()
                   || ownSid(sid)
                   || teacherOfSid(sid);
      allow write: if (isAdmin() || teacherOfSid(sid))
                   && (!("participacion" in request.resource.data)
                       || (request.resource.data.participacion is int
                           && request.resource.data.participacion >= 0
                           && request.resource.data.participacion <= 100))
                   && (!("examsGrade" in request.resource.data)
                       || (request.resource.data.examsGrade is int
                           && request.resource.data.examsGrade >= 0
                           && request.resource.data.examsGrade <= 100))
                   && (!("lessonsGrade" in request.resource.data)
                       || (request.resource.data.lessonsGrade is int
                           && request.resource.data.lessonsGrade >= 0
                           && request.resource.data.lessonsGrade <= 100));
    }

    /* ---------- rúbrica diaria del curso (daily_progress/{sid}) ----------
       Mismo esquema de permisos que gradebook. */
    match /daily_progress/{sid} {
      allow read:  if isAdmin()
                   || ownSid(sid)
                   || teacherOfSid(sid);
      allow write: if isAdmin() || teacherOfSid(sid);
    }

    /* ---------- analytics ligera (vesper_analytics.js) ----------
       Eventos anónimos (create sin sesión, con la apiKey pública). Solo
       CREATE con forma validada y tamaños acotados; leer/borrar, solo el
       admin (desde consola siempre se puede). Si no usas VA.cfg.cloud,
       puedes dejar este bloque igual: nadie escribe. */
    match /app_events/{id} {
      allow create: if request.resource.data.keys().hasOnly(
                         ["event", "props", "vid", "sid", "page", "createdAt"])
                    && request.resource.data.event is string
                    && request.resource.data.event.size() <= 64
                    && request.resource.data.props is string
                    && request.resource.data.props.size() <= 2000
                    && request.resource.data.vid is string
                    && request.resource.data.vid.size() <= 40
                    && request.resource.data.sid is string
                    && request.resource.data.sid.size() <= 40
                    && request.resource.data.page is string
                    && request.resource.data.page.size() <= 120
                    && request.resource.data.createdAt is timestamp;
      allow read:   if isAdmin();
      allow update, delete: if false;
    }

  }
}
