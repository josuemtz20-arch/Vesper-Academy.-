rules_version = '2';

/* ============================================================
 * Vesper Academy — Reglas de Firestore (base "teachermanuals")
 * ------------------------------------------------------------
 * Estas reglas gobiernan TODAS las colecciones que las páginas del
 * sitio leen/escriben con el idToken del usuario (Firebase Auth).
 *
 * ⚠️  IMPORTANTE: este archivo es la referencia COMPLETA reconstruida a
 *     partir del comportamiento del cliente. Lo nuevo que la boleta de
 *     calificaciones necesita son los bloques `gradebook` y `daily_progress`
 *     (el panel de resultados ya usa `exam_results`). Si ya tienes reglas
 *     publicadas para manuals/studentbooks/students/teachers, compara antes
 *     de reemplazar: lo más seguro es solo AÑADIR esos bloques a tus reglas
 *     actuales.
 *
 * Publica en: consola de Firebase → Firestore → base "teachermanuals" →
 * pestaña Reglas → pegar → Publicar. (O `firebase deploy --only
 * firestore:rules` si tienes firebase-tools configurado.)
 *
 * El alta/baja de manuales, libros y de la allowlist (students/teachers)
 * lo hace `_scripts/upload_manuals.py`, que INICIA SESIÓN COMO EL ADMIN
 * (signInWithPassword → idToken) y escribe por REST con ese token. Por eso
 * NO ignora estas reglas: la escritura en esas colecciones debe permitir al
 * admin (`isAdmin()`), no `if false`. (Solo sería `if false` si las subidas
 * usaran una service account / Admin SDK, que aquí NO se usa.)
 * ============================================================ */
service cloud.firestore {
  match /databases/{database}/documents {

    // El admin sube manuales/libros/allowlists con SU idToken (no service account).
    function isAdmin() {
      return request.auth != null
             && request.auth.token.email == "josuemtz20@gmail.com";
    }

    // —— Allowlist de acceso: cada quien lee SOLO su propio doc (id = correo) ——
    // vesper_auth.js consulta students/{correo} y teachers/{correo} con el
    // token del propio usuario para decidir si tiene acceso.
    match /students/{email} {
      allow read:  if request.auth != null && request.auth.token.email == email;
      allow write: if isAdmin();   // alta/baja desde el script admin
    }
    match /teachers/{email} {
      allow read:  if request.auth != null && request.auth.token.email == email;
      allow write: if isAdmin();
    }

    // —— Manuales del profesor: solo profesores autorizados o el admin ——
    // (manual.html → /documents/manuals/{id})
    match /manuals/{id} {
      allow read:  if request.auth != null && (
                     exists(/databases/$(database)/documents/teachers/$(request.auth.token.email))
                     || request.auth.token.email == "josuemtz20@gmail.com"
                   );
      allow write: if isAdmin();
      // el manual va troceado en la subcoleccion chunks/{n}: mismo permiso de lectura
      match /chunks/{n} {
        allow read:  if request.auth != null && (
                       exists(/databases/$(database)/documents/teachers/$(request.auth.token.email))
                       || request.auth.token.email == "josuemtz20@gmail.com"
                     );
        allow write: if isAdmin();
      }
    }

    // —— Libros del alumno: alumnos autorizados, profesores o el admin ——
    // (libro.html → /documents/studentbooks/{id})
    match /studentbooks/{id} {
      allow read:  if request.auth != null && (
                     exists(/databases/$(database)/documents/students/$(request.auth.token.email))
                     || exists(/databases/$(database)/documents/teachers/$(request.auth.token.email))
                     || request.auth.token.email == "josuemtz20@gmail.com"
                   );
      allow write: if isAdmin();
      // el libro va troceado en la subcoleccion chunks/{n}: mismo permiso de lectura
      match /chunks/{n} {
        allow read:  if request.auth != null && (
                       exists(/databases/$(database)/documents/students/$(request.auth.token.email))
                       || exists(/databases/$(database)/documents/teachers/$(request.auth.token.email))
                       || request.auth.token.email == "josuemtz20@gmail.com"
                     );
        allow write: if isAdmin();
      }
    }

    // —— Exámenes por curso/manual: alumnos autorizados, profesores o el admin ——
    // (exam.html → /documents/exams/{id}). Guardan las claves de respuesta, por eso
    // NO se publican como archivo estático; se leen con el idToken del alumno.
    match /exams/{id} {
      allow read:  if request.auth != null && (
                     exists(/databases/$(database)/documents/students/$(request.auth.token.email))
                     || exists(/databases/$(database)/documents/teachers/$(request.auth.token.email))
                     || request.auth.token.email == "josuemtz20@gmail.com"
                   );
      // alta/actualizacion SOLO desde la cuenta admin (upload_manuals.py upload-exams,
      // que inicia sesion como el admin y escribe con su idToken).
      allow write: if request.auth != null
                   && request.auth.token.email == "josuemtz20@gmail.com";
    }

    // —— Progreso del alumno (racha + XP): self-scoped ——
    // (vesper_sync.js → /documents/progress/{uid})
    match /progress/{uid} {
      allow read, write: if request.auth != null && request.auth.uid == uid;
    }

    // —— Liga semanal: lee cualquier autenticado; escribe SOLO su entrada ——
    // (vesper_league_cloud.js → /documents/leagues/{week}/members/{uid})
    match /leagues/{week}/members/{uid} {
      allow read:  if request.auth != null;
      allow write: if request.auth != null
                   && request.auth.uid == uid
                   && request.resource.data.xp is int;
    }

    // —— Resultados de exámenes: el alumno CREA lo suyo; el dueño,
    //    los profesores y el admin pueden LEER; intentos inmutables ——
    // (vesper_results.js → /documents/exam_results/{autoId})
    //
    // ⚠️  IMPORTANTE (integridad de la boleta): estos intentos los ESCRIBE el
    //     propio alumno (autocalificación en el navegador), así que NO son una
    //     fuente de verdad confiable para la calificación oficial. Sirven como
    //     PRÁCTICA/progreso; la nota de registro la confirma el profesor
    //     (ver vesper_gradebook.js / portal_boleta.html). Aun así validamos la
    //     coherencia interna del intento para bloquear las falsificaciones más
    //     burdas (percent que no cuadra con score/total, score>total, tipos de
    //     examen inventados).
    match /exam_results/{id} {
      allow create: if request.auth != null
                    && request.resource.data.studentUid == request.auth.uid
                    && request.resource.data.score is int
                    && request.resource.data.total is int
                    && request.resource.data.percent is int
                    && request.resource.data.score >= 0
                    && request.resource.data.total >= 0
                    && request.resource.data.score <= request.resource.data.total
                    && request.resource.data.percent >= 0
                    && request.resource.data.percent <= 100
                    // percent debe cuadrar con score/total (±1 por redondeo);
                    // si total==0 el percent debe ser 0.
                    && (
                         (request.resource.data.total == 0 && request.resource.data.percent == 0)
                         || (request.resource.data.total > 0
                             && request.resource.data.percent * request.resource.data.total
                                >= (request.resource.data.score * 100) - request.resource.data.total
                             && request.resource.data.percent * request.resource.data.total
                                <= (request.resource.data.score * 100) + request.resource.data.total)
                       )
                    // solo tipos de examen conocidos
                    && request.resource.data.examType in ["lesson", "exam", "boss", "placement"];
      allow read:   if request.auth != null && (
                       resource.data.studentUid == request.auth.uid
                       || exists(/databases/$(database)/documents/teachers/$(request.auth.token.email))
                       || request.auth.token.email == "josuemtz20@gmail.com"
                    );
      allow update, delete: if false;
    }

    // —— Boleta de calificaciones (NUEVO): participación capturada por el
    //    profesor. Un doc por alumno (id = correo en minúsculas). El alumno
    //    lee SOLO su boleta; profes/admin leen y escriben todas ——
    // (vesper_gradebook.js → /documents/gradebook/{correo};
    //  ver FIRESTORE_GRADEBOOK_RULES.md)
    match /gradebook/{email} {
      allow read:  if request.auth != null && (
                     request.auth.token.email == email
                     || exists(/databases/$(database)/documents/teachers/$(request.auth.token.email))
                     || request.auth.token.email == "josuemtz20@gmail.com"
                   );
      // escribe: SOLO profes/admin. Cada componente numérico (participacion,
      // examsGrade, lessonsGrade) es OPCIONAL por escritura, pero si está
      // presente debe ser int 0..100. examsGrade/lessonsGrade son la nota de
      // registro de Exámenes/Lecciones confirmada por el profesor (la única que
      // cuenta para la final; los promedios de práctica los escribe el alumno
      // en exam_results y NO se usan para la nota).
      allow write: if request.auth != null
                   && (exists(/databases/$(database)/documents/teachers/$(request.auth.token.email))
                       || request.auth.token.email == "josuemtz20@gmail.com")
                   && (!("participacion" in request.resource.data)
                       || (request.resource.data.participacion is int
                           && request.resource.data.participacion >= 0
                           && request.resource.data.participacion <= 100))
                   && (!("examsGrade" in request.resource.data)
                       || (request.resource.data.examsGrade is int
                           && request.resource.data.examsGrade >= 0
                           && request.resource.data.examsGrade <= 100))
                   && (!("lessonsGrade" in request.resource.data)
                       || (request.resource.data.lessonsGrade is int
                           && request.resource.data.lessonsGrade >= 0
                           && request.resource.data.lessonsGrade <= 100));
    }

    // —— Progreso diario (NUEVO): rúbrica del curso (20 días × aspectos,
    //    ✓/✗) capturada por el profesor. Un doc por alumno (id = correo en
    //    minúsculas). El alumno lee SOLO su rúbrica; profes/admin leen y
    //    escriben todas ——
    // (vesper_gradebook.js → /documents/daily_progress/{correo};
    //  ver FIRESTORE_GRADEBOOK_RULES.md)
    match /daily_progress/{email} {
      allow read:  if request.auth != null && (
                     request.auth.token.email == email
                     || exists(/databases/$(database)/documents/teachers/$(request.auth.token.email))
                     || request.auth.token.email == "josuemtz20@gmail.com"
                   );
      allow write: if request.auth != null
                   && (exists(/databases/$(database)/documents/teachers/$(request.auth.token.email))
                       || request.auth.token.email == "josuemtz20@gmail.com");
    }

  }
}
